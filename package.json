{
  "name": "@mauroandre/weave",
  "version": "0.0.0",
  "description": "Code-first object abstraction over PostgreSQL: think in nested objects, never write SQL.",
  "type": "module",
  "license": "MIT",
  "author": "Mauro André",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "weave": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "velojs dev",
    "build": "velojs build",
    "start": "velojs start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "postgres",
    "postgresql",
    "orm",
    "code-first",
    "object-relational",
    "typescript"
  ],
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@mauroandre/velojs": "^0.0.36",
    "@vanilla-extract/css": "^1.21.0",
    "@vanilla-extract/vite-plugin": "^5.2.3",
    "dotenv": "^17.4.2",
    "postgres": "^3.4.9"
  }
}
