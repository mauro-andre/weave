{
  "name": "@mauroandre/weave-sdk",
  "version": "0.0.0",
  "description": "Weave SDK — typed object client over the Weave HTTP API. The glue: entities-as-code in, objects out, HTTP/JSON invisible.",
  "type": "module",
  "license": "MIT",
  "author": "Mauro André",
  "bin": {
    "weave": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./cli": {
      "types": "./src/cli.ts",
      "import": "./src/cli.ts"
    }
  },
  "scripts": {
    "build": "tsup"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "weave",
    "postgres",
    "orm",
    "typed-client",
    "sdk",
    "typescript"
  ],
  "dependencies": {
    "@mauroandre/weave-core": "*"
  }
}
