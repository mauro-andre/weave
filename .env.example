# Copie para .env e ajuste se precisar.
# Casa com o docker-compose.yml (usuário/senha/db = weave).
DATABASE_URL=postgres://weave:weave@localhost:5432/weave

# Plataforma (control plane) — login do painel (estilo pgAdmin) e sessão.
MASTER_USERNAME=master
MASTER_PASSWORD=masterpass
SESSION_SECRET=change-me-in-prod
