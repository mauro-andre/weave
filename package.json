{
  "name": "@mauroandre/weave",
  "version": "0.0.0",
  "description": "Code-first object abstraction over PostgreSQL: think in nested objects, never write SQL.",
  "type": "module",
  "license": "MIT",
  "author": "Mauro André",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "weave": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:pg18 && npm run test:pg17",
    "test:pg18": "DATABASE_URL=postgres://weave:weave@localhost:5432/weave vitest run",
    "test:pg17": "DATABASE_URL=postgres://weave:weave@localhost:5433/weave vitest run",
    "test:watch": "vitest",
    "test:types": "vitest typecheck --run"
  },
  "keywords": [
    "postgres",
    "postgresql",
    "orm",
    "code-first",
    "object-relational",
    "typescript"
  ],
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "postgres": "^3.4.9"
  }
}
